% --- Theorem Environments ---
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[chapter]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem{fact}[theorem]{Fact}
\newtheorem{axiom}{Axiom}
\newtheorem{claim}{Claim}[theorem] % Numbered within theorems

\newtheorem*{AxExt}{Extendibility Axiom}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{notation}[theorem]{Notation}
\newtheorem{example}[theorem]{Example}
\newtheorem{question}{Question}[chapter]
\newtheorem{conjecture}{Conjecture}[chapter]

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}

% --- Special Claim Proof Environment ---
% Proof environment for claims that ends with a white square 
% to distinguish it from the main theorem proof (which ends with a black/filled square).
\newenvironment{claimproof}[1][Proof of Claim]{
    \begin{proof}[#1]
    \renewcommand{\qedsymbol}{$\dashv$} % Or \openbox
}{
    \end{proof}
}

