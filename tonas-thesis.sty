  {}

% --- Comments & Warnings ---
\newcommand{\cmt}[1]{
    \begin{mdframed}[backgroundcolor=SpringGreen!20,linecolor=OliveGreen!40,fontcolor=OliveGreen,roundcorner=5pt]
    #1
    \end{mdframed}
}

\newcommand{\warn}[1]{
    \begin{mdframed}[backgroundcolor=Red!10,linecolor=Red!40,fontcolor=Red,roundcorner=5pt]
    \faIcon{exclamation-triangle} #1
    \end{mdframed}
}