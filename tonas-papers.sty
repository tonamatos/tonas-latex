% --- Custom Callout Boxes ---
\newcommand{\cmt}[1]{
    \begin{mdframed}[backgroundcolor=SpringGreen!15, linecolor=OliveGreen!40, fontcolor=OliveGreen!80!black, roundcorner=5pt]
    \small #1
    \end{mdframed}
}

\newcommand{\warn}[1]{
    \begin{mdframed}[backgroundcolor=Red!10, linecolor=Red!40, fontcolor=Red!80!black, roundcorner=5pt]
    \small \faIcon{exclamation-triangle} \hspace{5pt} #1
    \end{mdframed}
}

% --- Abstract Styling ---
\renewenvironment{abstract}{
    \begin{center}
    {\bfseries \abstractname\vspace{-.5em}}
    \end{center}
    \quotation\small
}{\endquotation}

